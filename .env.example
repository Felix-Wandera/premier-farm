# ======================
# Database
# ======================
DATABASE_URL="postgresql://user:password@localhost:5432/premier_farm"

# ======================
# Authentication
# ======================
JWT_SECRET_KEY="your-secure-random-secret-key-min-32-chars"

# ======================
# Tech Admin (Global Bypass)
